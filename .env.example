# Core runtime
LLM_BACKEND=ollama
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434
OPENAI_MODEL=gpt-4o-mini

# Memory backend: chroma | simple
MEMORY_BACKEND=chroma

# Webhook security and allowlist
WHATSAPP_VERIFY_TOKEN=replace-with-a-random-verify-token
WHATSAPP_APP_SECRET=replace-with-your-meta-app-secret
ALLOWED_USERS=+6591111111,+6592222222

# WhatsApp Cloud API
WHATSAPP_API_VERSION=v21.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# Optional tuning
MAX_AGENT_STEPS=6
MAX_RESPONSE_CHARS=3500
